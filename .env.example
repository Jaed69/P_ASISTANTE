# ══════════════════════════════════════════════════════════════
# OpenClaw Fleet — Variables de entorno
# 1. Copia este archivo:  cp .env.example .env
# 2. Rellena los valores
# 3. Ejecuta:             ./setup.sh
# 4. Levanta:             docker compose up -d
# NUNCA subas .env a git
# ══════════════════════════════════════════════════════════════

# ── OPENROUTER ───────────────────────────────────────────────
# Obtén tu clave en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME

# ── BOTS ACTIVOS ─────────────────────────────────────────────
# Lista separada por espacios — setup.sh configura uno por cada nombre
BOTS="personal researcher"

# ── OPCIONES GLOBALES ─────────────────────────────────────────
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.15
TZ=America/Lima

# ══════════════════════════════════════════════════════════════
# CONFIGURACIÓN POR BOT
# Para cada bot define: <nombre>_TELEGRAM_TOKEN, <nombre>_MODEL
# <nombre>_TOKEN se genera automáticamente con setup.sh (no lo rellenes a mano)
# Todos los bots se acceden vía nginx en http://127.0.0.1:18788/<nombre>/
# ══════════════════════════════════════════════════════════════

# ── Bot: personal ─────────────────────────────────────────────
personal_TELEGRAM_TOKEN=          # Token de @BotFather para este bot
personal_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
personal_TOKEN=                   # ← auto-generado por setup.sh

# ── Bot: researcher ───────────────────────────────────────────
researcher_TELEGRAM_TOKEN=        # Token de @BotFather para este bot
researcher_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
researcher_TOKEN=                 # ← auto-generado por setup.sh

# ══════════════════════════════════════════════════════════════
# PARA AGREGAR UN NUEVO BOT:
#   1. Agrega su nombre a BOTS="personal researcher NUEVO_BOT"
#   2. Agrega su config aquí:
#      nuevo_TELEGRAM_TOKEN=
#      nuevo_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
#      nuevo_TOKEN=
#   3. Crea su personalidad en bots/nuevo/config/SOUL.md
#   4. Ejecuta ./setup.sh && docker compose up -d
# ══════════════════════════════════════════════════════════════
